etrieve","type":"string"}}},"strict":false}},{"type":"function","function":{"name":"feishu_bitable_create_record","description":"Create a new record (row) in a Bitable table","parameters":{"type":"object","required":["app_token","table_id","fields"],"properties":{"app_token":{"description":"Bitable app token (use feishu_bitable_get_meta to get from URL)","type":"string"},"table_id":{"description":"Table ID (from URL: ?table=YYY)","type":"string"},"fields":{"description":"Field values keyed by field name. Format by type: Text='string', Number=123, SingleSelect='Option', MultiSelect=['A','B'], DateTime=timestamp_ms, User=[{id:'ou_xxx'}], URL={text:'Display',link:'https://...'}","type":"object","patternProperties":{"^(.*)$":{}}}}},"strict":false}},{"type":"function","function":{"name":"feishu_bitable_update_record","description":"Update an existing record (row) in a Bitable table","parameters":{"type":"object","required":["app_token","table_id","record_id","fields"],"properties":{"app_token":{"description":"Bitable app token (use feishu_bitable_get_meta to get from URL)","type":"string"},"table_id":{"description":"Table ID (from URL: ?table=YYY)","type":"string"},"record_id":{"description":"Record ID to update","type":"string"},"fields":{"description":"Field values to update (same format as create_record)","type":"object","patternProperties":{"^(.*)$":{}}}}},"strict":false}},{"type":"function","function":{"name":"feishu_bitable_create_app","description":"Create a new Bitable (multidimensional table) application","parameters":{"type":"object","required":["name"],"properties":{"name":{"description":"Name for the new Bitable application","type":"string"},"folder_token":{"description":"Optional folder token to place the Bitable in a specific folder","type":"string"}}},"strict":false}},{"type":"function","function":{"name":"feishu_bitable_create_field","description":"Create a new field (column) in a Bitable table","parameters":{"type":"object","required":["app_token","table